# Copy this file to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Edge TTS voice (free, unlimited, Microsoft neural voices).
# Alternatives: en-US-GuyNeural, en-US-AndrewMultilingualNeural, en-US-BrianNeural
TTS_VOICE=en-US-ChristopherNeural
TTS_RATE=-8%

# Niche + language
NICHE=history
LANGUAGE=English
TARGET_VIEWS=1000000

# YouTube OAuth (client_secret.json must be placed at repo root)
YOUTUBE_CLIENT_SECRET_PATH=client_secret.json
YOUTUBE_TOKEN_PATH=token.json
YOUTUBE_PRIVACY=public
