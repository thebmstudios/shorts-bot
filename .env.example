# Copy this file to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-xxxxx
ELEVENLABS_API_KEY=xxxxx
ELEVENLABS_VOICE_ID=pqHfZKP75CvOlQylNhV4             # primary (Bill — deep narrator)
ELEVENLABS_VOICE_ID_SECONDARY=21m00Tcm4TlvDq8ikWAM    # secondary (Rachel — alternates per sentence). Leave blank to use one voice.

# Niche + language
NICHE=history
